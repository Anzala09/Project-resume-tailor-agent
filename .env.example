# ─────────────────────────────────────────────────────
#  LLM Provider — set ONE of the following (not both)
# ─────────────────────────────────────────────────────

# PRIMARY (FREE): Google Gemini 1.5 Flash
# Get your free key at: https://aistudio.google.com/app/apikey
# No credit card required — just a Google account.
GEMINI_API_KEY=your_gemini_api_key_here

# ALTERNATIVE (paid): Anthropic Claude Sonnet
# Uncomment and fill in if you prefer Anthropic.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─────────────────────────────────────────────────────
#  Gmail — for sending tailored resumes
# ─────────────────────────────────────────────────────

# Your Gmail address
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your account password)
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification to be enabled on your account.
GMAIL_APP_PASSWORD=your_16_char_app_password

# Destination email for all 5 tailored resumes
EMAIL_RECIPIENT=recipient@example.com
